{
  "name": "ai-translator",
  "version": "1.0.0",
  "description": "Translate PDF, DOCX, and TXT documents into Persian using Ollama and TypeScript",
  "author": "Zahra Jafari Fard",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "worker": "tsx watch src/workers/translation.worker.ts",
    "start": "tsx src/index.ts",
    "dev": "tsx --watch src/index.ts",
    "test": "echo \"No tests configured yet\" && exit 0"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "bullmq": "^5.79.4",
    "cors": "^2.8.6",
    "docx": "^9.7.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "mysql2": "^3.22.6",
    "p-limit": "^7.3.0",
    "pdfjs-dist": "^6.1.200",
    "pdfkit": "^0.19.1",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.2.0",
    "@types/node": "^26.1.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/pdfkit": "^0.17.6",
    "@types/sequelize": "^4.28.20",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
